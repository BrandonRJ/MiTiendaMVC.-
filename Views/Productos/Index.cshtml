@using System.Web.Optimization
@model IEnumerable<string>

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MiTiendaMVC</title>
    @Styles.Render("~/Content/css")
</head>
<body>
    <div class="container">
        <header>
            @* Datos de ViewData y ViewBag *@
            <h1>@ViewData["TituloPagina"]</h1>
            <p class="mensaje-info">@ViewBag.MensajeInformativo</p>
        </header>

        @* TempData con estilo de alerta *@
        @if (TempData["EstadoConexion"] != null)
        {
            <div class="alert">
                <strong>Sincronización:</strong> @TempData["EstadoConexion"]
            </div>
        }

        <section>
            <h2>Tareas en Agenda</h2>

            @* Lógica Condicional *@
            @if (Model != null && Model.Any())
            {
                <ul>
                    @* Bucle foreach *@
                    @foreach (var tarea in Model)
                    {
                        <li>@tarea</li>
                    }
                </ul>
            }
            else
            {
                <p class="empty">No hay tareas pendientes para hoy.</p>
            }
        </section>
    </div>
</body>
</html>